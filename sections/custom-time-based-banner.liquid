{% liquid
  assign now = 'now' | date: '%s'

  assign active_banner = null
  assign active_products = null

  # ---------- CHECK BANNER TIMER ----------
  for banner in shop.metaobjects.time_based_banner.values
    assign start = banner.start_hour.value | date: '%s'
    assign end = banner.end_hour.value | date: '%s'

    if start <= now and now < end
      assign active_banner = banner
      break
    endif
  endfor

  # ---------- CHECK PRODUCT TIMER (ONLY IF NO BANNER) ----------
  if active_banner == null
    for entry in shop.metaobjects.product_based_timer.values
      assign start = entry.start_time.value | date: '%s'
      assign end = entry.end_time.value | date: '%s'

      if start <= now and now < end and entry.product_detail.value != blank
        assign active_products = entry.product_detail.value
        break
      endif
    endfor
  endif
%}

<p style="display:none;">Now: {{ now | date: '%A, %B %d, %Y %I:%M %p' }}</p>

{% if active_banner or active_products %}
  <section class="custom-time-based-section">
    {% if section.settings.section_heading != blank %}
      <h2 class="section-heading">{{ section.settings.section_heading }}</h2>
    {% endif %}

    {% if active_banner %}
      <!-- ================= BANNER ================= -->

      <div class="image-banner-overlay">
        {% if active_banner.banner_image.value %}
          <img
            src="{{ active_banner.banner_image.value | image_url: width: 2000 }}"
            alt="{{ active_banner.heading.value }}"
            class="banner-image"
          >
        {% endif %}

        <div class="banner-content">
          <h3>{{ active_banner.heading.value }}</h3>
          <p>{{ active_banner.description.value }}</p>

          {% if active_banner.button_text.value != blank %}
            <a href="{{ active_banner.button_url.value }}" class="banner-btn">
              {{ active_banner.button_text.value }}
            </a>
          {% endif %}
        </div>
      </div>

    {% elsif active_products %}
      <!-- ================= PRODUCTS ================= -->
      <div class="products-grid">
        {% for product in active_products %}
          <div class="product-card">
            {% if product.featured_image %}
              <img
                src="{{ product.featured_image | image_url: width: 800 }}"
                alt="{{ product.title }}"
                loading="lazy"
              >
            {% endif %}

            <h3>{{ product.title }}</h3>
            <p class="price">{{ product.price | money }}</p>

            <button
              class="btn add-to-cart-btn"
              data-variant-id="{{ product.selected_or_first_available_variant.id }}"
            >
              Add to Cart
            </button>
          </div>
        {% endfor %}
      </div>
    {% endif %}
  </section>
{% endif %}
<style>
      .custom-time-based-section {
    padding: 60px 20px;
  }

  .section-heading {
    text-align: center;
    font-size: 36px;
    margin-bottom: 40px;
  }

  /* ===== Banner ===== */
  .image-banner-overlay {
    position: relative;
    min-height: 500px;
    overflow: hidden;
  }

  .banner-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .banner-content {
    position: relative;
    z-index: 2;
    max-width: 600px;
    padding: 40px;
    color: #ffffff;
  }

  .banner-btn {
    display: inline-block;
    padding: 14px 28px;
    background: #000;
    color: #fff;
    text-decoration: none;
    border-radius: 4px;
  }

  /* ===== Products ===== */
  .products-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 24px;
  }

  .product-card {
    background: #fff;
    padding: 20px;
    border-radius: 8px;
    text-align: center;
  }

  .product-card img {
    width: 100%;
    height: 250px;
    object-fit: cover;
    margin-bottom: 12px;
  }

  .product-card h3 {
    font-size: 18px;
    margin-bottom: 6px;
  }

  .price {
    margin-bottom: 10px;
  }

  .btn {
    padding: 10px 20px;
    background: #000;
    color: #fff;
    text-decoration: none;
    border-radius: 4px;
  }
</style>
<script type="module">
  import { CartAddEvent } from '@theme/events';

  document.addEventListener('click', async (e) => {
    const btn = e.target.closest('.add-to-cart-btn');
    if (!btn) return;

    e.preventDefault();

    const variantId = btn.dataset.variantId;
    if (!variantId) return;

    btn.setAttribute('aria-disabled', 'true');
    btn.textContent = 'Adding…';

    try {
      await fetch('/cart/add.js', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          Accept: 'application/json',
        },
        body: JSON.stringify({
          id: variantId,
          quantity: 1,
        }),
      });

      /* 🔥 THIS IS THE KEY LINE */
      document.dispatchEvent(new CartAddEvent());

      btn.textContent = 'Added ✓';
    } catch (err) {
      console.error(err);
      btn.textContent = 'Error';
    } finally {
      setTimeout(() => {
        btn.textContent = 'Add to Cart';
        btn.removeAttribute('aria-disabled');
      }, 1200);
    }
  });
</script>

{% schema %}
{
  "name": "Custom Time Based Section",
  "settings": [
    {
      "type": "text",
      "id": "section_heading",
      "label": "Section Heading"
    }
  ],
  "presets": [
    {
      "name": "Custom Time Based Section"
    }
  ]
}
{% endschema %}
